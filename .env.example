# Copiez ce fichier en ".env" et remplissez les valeurs réelles.
# Ne JAMAIS committer le fichier ".env" (voir .gitignore).

# --- WhatsApp Cloud API (Meta for Developers) ---
# Guide pas à pas dans README.md section "Obtenir ces valeurs"
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v20.0

# Chaîne que VOUS choisissez, à renseigner aussi dans la console Meta lors de
# la configuration du webhook (n'importe quelle chaîne secrète suffit).
WHATSAPP_VERIFY_TOKEN=sos-inondation-verify-2026

# --- Base de données (Supabase) ---
# Le projet "sos-inondation" a déjà été créé avec les 6 tables du modèle de
# données (voir README section "Base de données"). Il ne reste qu'à copier
# ces deux valeurs depuis Project Settings -> API dans le dashboard Supabase.
SUPABASE_URL=https://hreqnarxxhfqjqhcxanc.supabase.co
# Settings -> API -> "service_role" (secret, PAS la clé "anon"/"publishable")
SUPABASE_SERVICE_ROLE_KEY=

# --- Divers ---
PORT=3000
# URL publique de votre déploiement (Render/Railway vous la donne après le 1er déploiement)
PUBLIC_BASE_URL=http://localhost:3000
